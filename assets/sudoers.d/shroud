# Shroud VPN Kill Switch - Sudoers Configuration
# Version: 2
#
# This file allows passwordless iptables/ip6tables/nft for kill switch management.
# Supports multiple Linux distributions with different binary locations.
#
# Compatibility:
#   - Arch Linux, Manjaro: /usr/bin/*
#   - Debian, Ubuntu: /usr/sbin/*
#   - Fedora, RHEL, CentOS: /usr/sbin/*
#   - openSUSE: /usr/sbin/*
#
# Remove this file to revoke: sudo rm /etc/sudoers.d/shroud
# Reinstall with: ./setup.sh --install-sudoers

# Wheel group (Arch, Fedora, RHEL, openSUSE)
%wheel ALL=(ALL) NOPASSWD: /usr/bin/iptables
%wheel ALL=(ALL) NOPASSWD: /usr/bin/iptables-legacy
%wheel ALL=(ALL) NOPASSWD: /usr/bin/iptables-nft
%wheel ALL=(ALL) NOPASSWD: /usr/bin/ip6tables
%wheel ALL=(ALL) NOPASSWD: /usr/bin/ip6tables-legacy
%wheel ALL=(ALL) NOPASSWD: /usr/bin/ip6tables-nft
%wheel ALL=(ALL) NOPASSWD: /usr/bin/nft
%wheel ALL=(ALL) NOPASSWD: /usr/sbin/iptables
%wheel ALL=(ALL) NOPASSWD: /usr/sbin/iptables-legacy
%wheel ALL=(ALL) NOPASSWD: /usr/sbin/iptables-nft
%wheel ALL=(ALL) NOPASSWD: /usr/sbin/ip6tables
%wheel ALL=(ALL) NOPASSWD: /usr/sbin/ip6tables-legacy
%wheel ALL=(ALL) NOPASSWD: /usr/sbin/ip6tables-nft
%wheel ALL=(ALL) NOPASSWD: /usr/sbin/nft

# Sudo group (Debian, Ubuntu)
%sudo ALL=(ALL) NOPASSWD: /usr/bin/iptables
%sudo ALL=(ALL) NOPASSWD: /usr/bin/iptables-legacy
%sudo ALL=(ALL) NOPASSWD: /usr/bin/iptables-nft
%sudo ALL=(ALL) NOPASSWD: /usr/bin/ip6tables
%sudo ALL=(ALL) NOPASSWD: /usr/bin/ip6tables-legacy
%sudo ALL=(ALL) NOPASSWD: /usr/bin/ip6tables-nft
%sudo ALL=(ALL) NOPASSWD: /usr/bin/nft
%sudo ALL=(ALL) NOPASSWD: /usr/sbin/iptables
%sudo ALL=(ALL) NOPASSWD: /usr/sbin/iptables-legacy
%sudo ALL=(ALL) NOPASSWD: /usr/sbin/iptables-nft
%sudo ALL=(ALL) NOPASSWD: /usr/sbin/ip6tables
%sudo ALL=(ALL) NOPASSWD: /usr/sbin/ip6tables-legacy
%sudo ALL=(ALL) NOPASSWD: /usr/sbin/ip6tables-nft
%sudo ALL=(ALL) NOPASSWD: /usr/sbin/nft
