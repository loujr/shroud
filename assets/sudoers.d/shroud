# Shroud VPN Kill Switch - Sudoers Configuration
# Version: 3
#
# SECURITY: Rules are scoped to Shroud's chain operations.
# iptables/ip6tables: only SHROUD_* chain management + OUTPUT chain jumps.
# nft: only shroud table operations and stdin-only ruleset loading (no -f /path).
#
# Compatibility:
#   - Arch Linux, Manjaro: /usr/bin/*
#   - Debian, Ubuntu: /usr/sbin/*
#   - Fedora, RHEL, CentOS: /usr/sbin/*
#   - openSUSE: /usr/sbin/*
#
# Remove this file to revoke: sudo rm /etc/sudoers.d/shroud
# Reinstall with: ./setup.sh --install-sudoers

# Wheel group (Arch, Fedora, RHEL, openSUSE)
%wheel ALL=(ALL) NOPASSWD: /usr/bin/iptables -N SHROUD_*
%wheel ALL=(ALL) NOPASSWD: /usr/bin/iptables -F SHROUD_*
%wheel ALL=(ALL) NOPASSWD: /usr/bin/iptables -X SHROUD_*
